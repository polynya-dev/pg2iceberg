{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Pipeline Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "Stopped" }, "1": { "text": "Starting" }, "2": { "text": "Snapshotting" }, "3": { "text": "Running" }, "4": { "text": "Stopping" }, "5": { "text": "Error" } }, "type": "value" }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 1 }, { "color": "blue", "value": 2 }, { "color": "green", "value": 3 }, { "color": "yellow", "value": 4 }, { "color": "red", "value": 5 }] }
        },
        "overrides": []
      },
      "targets": [{ "expr": "pg2iceberg_pipeline_status", "legendFormat": "{{pipeline}}" }]
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [{ "expr": "pg2iceberg_pipeline_uptime_seconds", "legendFormat": "{{pipeline}}" }]
    },
    {
      "title": "Rows Processed (rate/s)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [{ "expr": "sum(rate(pg2iceberg_rows_processed_total[1m]))", "legendFormat": "rows/s" }]
    },
    {
      "title": "Bytes Processed (rate/s)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [{ "expr": "sum(rate(pg2iceberg_bytes_processed_total[1m]))", "legendFormat": "bytes/s" }]
    },
    {
      "title": "Replication Lag",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 16777216 }, { "color": "red", "value": 104857600 }] }
        },
        "overrides": []
      },
      "targets": [{ "expr": "pg2iceberg_replication_lag_bytes", "legendFormat": "{{pipeline}}" }]
    },
    {
      "title": "WAL Retained",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 104857600 }, { "color": "red", "value": 1073741824 }] }
        },
        "overrides": []
      },
      "targets": [{ "expr": "pg2iceberg_wal_retained_bytes", "legendFormat": "{{pipeline}}" }]
    },
    {
      "title": "Rows Processed by Table & Operation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [{ "expr": "rate(pg2iceberg_rows_processed_total[1m])", "legendFormat": "{{table}} {{operation}}" }]
    },
    {
      "title": "Buffered Events & Bytes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [{ "matcher": { "id": "byName", "options": "bytes" }, "properties": [{ "id": "unit", "value": "decbytes" }, { "id": "custom.axisPlacement", "value": "right" }] }] },
      "targets": [
        { "expr": "pg2iceberg_events_buffered", "legendFormat": "events" },
        { "expr": "pg2iceberg_bytes_buffered", "legendFormat": "bytes" }
      ]
    },
    {
      "title": "Flush Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(pg2iceberg_flush_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(pg2iceberg_flush_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(pg2iceberg_flush_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "title": "Flush Rate & Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 50 } }, "overrides": [{ "matcher": { "id": "byName", "options": "errors" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }] },
      "targets": [
        { "expr": "rate(pg2iceberg_flush_total[1m])", "legendFormat": "flushes/s" },
        { "expr": "rate(pg2iceberg_flush_errors_total[1m])", "legendFormat": "errors" }
      ]
    },
    {
      "title": "Flush Rows (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "rows/s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [{ "expr": "rate(pg2iceberg_flush_rows_total[1m])", "legendFormat": "{{pipeline}}" }]
    },
    {
      "title": "S3 Operation Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(pg2iceberg_s3_operation_duration_seconds_bucket[5m]))", "legendFormat": "{{operation}} p95" }
      ]
    },
    {
      "title": "S3 Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "expr": "rate(pg2iceberg_s3_bytes_uploaded_total[1m])", "legendFormat": "upload" },
        { "expr": "rate(pg2iceberg_s3_bytes_downloaded_total[1m])", "legendFormat": "download" }
      ]
    },
    {
      "title": "Catalog Operation Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(pg2iceberg_catalog_operation_duration_seconds_bucket[5m]))", "legendFormat": "{{operation}} p95" }
      ]
    },
    {
      "title": "Replication Lag Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "decbytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "expr": "pg2iceberg_replication_lag_bytes", "legendFormat": "lag {{pipeline}}" },
        { "expr": "pg2iceberg_wal_retained_bytes", "legendFormat": "WAL retained {{pipeline}}" }
      ]
    },
    {
      "title": "Confirmed LSN",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "targets": [{ "expr": "pg2iceberg_confirmed_lsn", "legendFormat": "{{pipeline}}" }]
    },
    {
      "title": "TOAST Lookups",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 50 } }, "overrides": [] },
      "targets": [
        { "expr": "rate(pg2iceberg_toast_lookups_total[1m])", "legendFormat": "lookups {{table}}" },
        { "expr": "rate(pg2iceberg_toast_rows_resolved_total[1m])", "legendFormat": "rows {{table}}" }
      ]
    },
    {
      "title": "Compaction Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(pg2iceberg_compaction_duration_seconds_bucket[5m]))", "legendFormat": "{{table}} p95" }
      ]
    },
    {
      "title": "Compaction Rows",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 50 } }, "overrides": [] },
      "targets": [
        { "expr": "rate(pg2iceberg_compaction_input_rows_total[5m])", "legendFormat": "input {{table}}" },
        { "expr": "rate(pg2iceberg_compaction_deleted_rows_total[5m])", "legendFormat": "deleted {{table}}" }
      ]
    },
    {
      "title": "Snapshot Progress",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "expr": "pg2iceberg_snapshot_rows_total", "legendFormat": "{{table}} rows" },
        { "expr": "pg2iceberg_snapshot_tables_completed_total", "legendFormat": "tables completed" }
      ]
    },
    {
      "title": "Snapshot In Progress",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "0": { "text": "No" }, "1": { "text": "Yes" } }, "type": "value" }],
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "blue", "value": 1 }] }
        },
        "overrides": []
      },
      "targets": [{ "expr": "pg2iceberg_snapshot_in_progress", "legendFormat": "{{pipeline}}" }]
    },
    {
      "title": "S3 Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 50 }, "color": { "fixedColor": "red", "mode": "fixed" } }, "overrides": [] },
      "targets": [
        { "expr": "rate(pg2iceberg_s3_errors_total[1m])", "legendFormat": "{{operation}}" },
        { "expr": "rate(pg2iceberg_catalog_errors_total[1m])", "legendFormat": "catalog {{operation}}" }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["pg2iceberg"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "title": "pg2iceberg",
  "uid": "pg2iceberg"
}
